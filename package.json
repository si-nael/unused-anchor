{
    "name": "unused-anchor",
    "version": "0.4.9",
    "private": true,
    "description": "Bubbles language bootstrap for procedural world definition and inspection.",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "check": "tsc -p tsconfig.json --noEmit",
        "verify:core": "npm run check && npm test",
        "verify:records": "tsx --test tests/unit/research-records.test.ts",
        "verify:examples": "npm run validate:example && npm run compile:example && npm run inspect:boundary-example && npm run compile:grammar-example && npm run inspect:grammar-example && npm run inspect:grammar-chain-example && npm run plan:meta-example && npm run materialize:meta-example && npm run inspect:meta-example && npm run materialize:observatory-example && npm run inspect:observatory-example",
        "verify:collapse": "npm run materialize:collapse-example && npm run inspect:collapse-example && npm run materialize:collapse-open-example && npm run inspect:collapse-open-example && npm run materialize:collapse-mixed-example && npm run inspect:collapse-mixed-example",
        "verify:replay": "npm run record:collapse-mirror-example && npm run inspect:collapse-mirror-example && npm run replay:collapse-mirror-example && npm run record:meta-example && npm run replay:meta-example",
        "verify:attribution": "npm run materialize:attribution-example && npm run inspect:attribution-example && npm run record:attribution-example && npm run replay:attribution-example",
        "verify": "npm run verify:core && npm run verify:examples && npm run verify:collapse && npm run verify:replay && npm run verify:attribution",
        "validate:example": "tsx apps/hatchery/compile-bubble.ts --check examples/first-world.bubble",
        "compile:example": "tsx apps/hatchery/compile-bubble.ts examples/first-world.bubble data/runs/first-world.ir.json",
        "inspect:boundary-example": "tsx apps/hatchery/inspect-bubble.ts examples/boundary-orchard.bubble data/runs/boundary-orchard.inspect.json --section report",
        "compile:grammar-example": "tsx apps/hatchery/compile-bubble.ts examples/grammar-nursery.bubble data/runs/grammar-nursery.ir.json",
        "inspect:grammar-example": "tsx apps/hatchery/inspect-bubble.ts examples/grammar-nursery.bubble data/runs/grammar-nursery.inspect.json --section grammars",
        "inspect:grammar-chain-example": "tsx apps/hatchery/inspect-bubble.ts examples/grammar-canopy.bubble data/runs/grammar-canopy.inspect.json --section grammars",
        "plan:meta-example": "tsx apps/hatchery/plan-bubble.ts examples/meta-grove.bubble data/runs/meta-grove.plan.json",
        "materialize:meta-example": "tsx apps/hatchery/materialize-bubble.ts examples/meta-grove.bubble data/runs/meta-grove.materialized.json",
        "inspect:meta-example": "tsx apps/hatchery/inspect-bubble.ts examples/meta-grove.bubble data/runs/meta-grove.inspect.json --section report",
        "materialize:observatory-example": "tsx apps/hatchery/materialize-bubble.ts examples/observatory-loop.bubble data/runs/observatory-loop.materialized.json",
        "inspect:observatory-example": "tsx apps/hatchery/inspect-bubble.ts examples/observatory-loop.bubble data/runs/observatory-loop.inspect.json --section report",
        "materialize:collapse-example": "tsx apps/hatchery/materialize-bubble.ts examples/collapse-threshold.bubble data/runs/collapse-threshold.materialized.json",
        "inspect:collapse-example": "tsx apps/hatchery/inspect-bubble.ts examples/collapse-threshold.bubble data/runs/collapse-threshold.inspect.json --section report",
        "materialize:collapse-open-example": "tsx apps/hatchery/materialize-bubble.ts examples/collapse-open.bubble data/runs/collapse-open.materialized.json",
        "inspect:collapse-open-example": "tsx apps/hatchery/inspect-bubble.ts examples/collapse-open.bubble data/runs/collapse-open.inspect.json --section report",
        "materialize:collapse-mixed-example": "tsx apps/hatchery/materialize-bubble.ts examples/collapse-mixed.bubble data/runs/collapse-mixed.materialized.json",
        "inspect:collapse-mixed-example": "tsx apps/hatchery/inspect-bubble.ts examples/collapse-mixed.bubble data/runs/collapse-mixed.inspect.json --section report",
        "record:collapse-mirror-example": "tsx apps/hatchery/record-bubble.ts examples/collapse-mirror.bubble data/runs/collapse-mirror.replay.json",
        "inspect:collapse-mirror-example": "tsx apps/hatchery/inspect-bubble.ts examples/collapse-mirror.bubble data/runs/collapse-mirror.inspect.json --section report",
        "replay:collapse-mirror-example": "tsx apps/hatchery/replay-bubble.ts data/runs/collapse-mirror.replay.json data/runs/collapse-mirror.replayed-report.json --section report",
        "record:meta-example": "tsx apps/hatchery/record-bubble.ts examples/meta-grove.bubble data/runs/meta-grove.replay.json",
        "replay:meta-example": "tsx apps/hatchery/replay-bubble.ts data/runs/meta-grove.replay.json data/runs/meta-grove.replayed-summary.json --section summary",
        "materialize:attribution-example": "tsx apps/hatchery/materialize-bubble.ts examples/attribution-crossroads.bubble data/runs/attribution-crossroads.materialized.json",
        "inspect:attribution-example": "tsx apps/hatchery/inspect-bubble.ts examples/attribution-crossroads.bubble data/runs/attribution-crossroads.inspect.json --section sourceAttributions --attribution-status unresolved",
        "record:attribution-example": "tsx apps/hatchery/record-bubble.ts examples/attribution-crossroads.bubble data/runs/attribution-crossroads.replay.json",
        "replay:attribution-example": "tsx apps/hatchery/replay-bubble.ts data/runs/attribution-crossroads.replay.json data/runs/attribution-crossroads.replayed-attributions.json --section sourceAttributions --attribution-status unresolved",
        "test": "tsx --test tests/unit/**/*.test.ts"
    },
    "devDependencies": {
        "@types/node": "^24.0.1",
        "tsx": "^4.19.3",
        "typescript": "^5.8.3"
    }
}
